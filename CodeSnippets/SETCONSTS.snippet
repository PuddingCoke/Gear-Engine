<?xml version="1.0" encoding="utf-8"?>
<CodeSnippets xmlns="http://schemas.microsoft.com/VisualStudio/2005/CodeSnippet">
	<CodeSnippet Format="1.0.0">
		<Header>
			<Title>SETCONSTS</Title>
			<Shortcut>SETCONSTS</Shortcut>
			<Description>展开 SETCONSTS 宏调用</Description>
			<SnippetTypes>
				<SnippetType>Expansion</SnippetType>
			</SnippetTypes>
		</Header>
		<Snippet>
			<Code Language="CPP">
				<![CDATA[SETCONSTS({
  $end$
  });]]>
			</Code>
		</Snippet>
	</CodeSnippet>
</CodeSnippets>